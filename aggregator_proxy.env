# NSI Aggregator Proxy configuration
#
# Copy this file and fill in the values for your environment.
# Environment variables take precedence over values in this file.
# Lines starting with # are comments. Uncomment and edit the lines you need.

# --- Required ---

# Full URL of the NSI provider endpoint on the aggregator.
# PROVIDER_URL=https://aggregator.example.com/nsi-v2/ConnectionServiceProvider

# NSA URN used as requesterNSA in query requests to the aggregator.
# REQUESTER_NSA=urn:ogf:network:example.com:2025:requester-nsa

# NSA URN of the aggregator; used as providerNSA in all outbound SOAP headers.
# PROVIDER_NSA=urn:ogf:network:example.com:2025:provider-nsa

# Externally reachable base URL of this proxy; /nsi/v2/callback is appended for replyTo.
# BASE_URL=https://proxy.example.com

# --- Optional: mTLS towards the aggregator ---

# Path to client TLS certificate.
# CLIENT_CERT=

# Path to client TLS private key.
# CLIENT_KEY=

# Path to CA bundle for server certificate verification.
# CA_FILE=

# --- Optional: Timeouts ---

# Seconds to wait for async NSI callbacks (reserve, commit, provision, release, terminate).
# NSI_TIMEOUT=180

# Seconds to wait for DataPlaneStateChange after provision or release.
# DATAPLANE_TIMEOUT=300

# --- Optional: Server ---

# Log level (DEBUG, INFO, WARNING, ERROR).
# LOG_LEVEL=INFO

# Bind host.
# HOST=0.0.0.0

# Bind port.
# PORT=8080

# ASGI root path prefix. Set when behind a reverse proxy that strips a path prefix.
# ROOT_PATH=

# --- Optional: Authentication for REST + callback ---

# Enable authentication on all reservation endpoints and on /openapi.json, /docs,
# and /redoc. When true, every request to these paths must carry trusted identity
# headers set by the edge proxy (oauth2-proxy) or the mTLS header set by nsi-auth.
# The /health endpoint is always unauthenticated. The /nsi/v2/callback endpoint
# accepts only the mTLS header (browser/OIDC users are rejected).
# PROXY_AUTH_ENABLED=false

# Header name that nsi-auth sets on successful mTLS validation (e.g. X-Auth-Method).
# When set and auth is enabled, the presence of this header counts as mTLS
# authentication and X-Client-DN is logged for audit.
# MTLS_HEADER=

# Groups required for access. JSON array or comma-separated. Use [] for no group
# check (any authenticated user is allowed). Matched against the parsed
# X-Auth-Request-Groups header (comma- or whitespace-separated). Must include
# the URNs returned by both the portal OIDC provider and (when MCP is enabled)
# the MCP OIDC provider — a single list gates both surfaces.
# OIDC_REQUIRED_GROUPS=[]

# --- Optional: MCP server ---

# Mount the MCP sub-app at MCP_PATH.
# MCP_ENABLED=false

# Path at which the MCP sub-app is mounted.
# MCP_PATH=/mcp

# Validate incoming MCP requests' JWTs against MCP_OIDC_* settings. Must be true
# when PROXY_AUTH_ENABLED and MCP_ENABLED are both true; the Settings model
# validator refuses the unsafe combination at startup.
# MCP_AUTH_ENABLED=false

# JWKS URI for the MCP OIDC provider (separate from the portal IdP).
# MCP_OIDC_JWKS_URI=

# Expected issuer claim for MCP-issued JWTs.
# MCP_OIDC_ISSUER=

# Expected audience claim for MCP-issued JWTs.
# MCP_OIDC_AUDIENCE=

# JWT claim names that the claim-translation hook reads to populate
# X-Auth-Request-Email and X-Auth-Request-Groups on the internal MCP→REST call.
# MCP_OIDC_EMAIL_CLAIM=email
# MCP_OIDC_GROUPS_CLAIM=groups
